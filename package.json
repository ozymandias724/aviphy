{
  "name": "@ozymandias724/aviphy",
  "version": "0.4.0",
  "description": "Animated GIF/WebP to animated AVIF conversion with bundled avifenc binaries, Buffer support, and a packaged CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./index.ts ./src/cli.ts --outdir ./dist --target node && tsc -p tsconfig.build.json",
    "test": "bun test"
  },
  "bin": {
    "aviphy": "./dist/src/cli.js"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ozymandias724/aviphy.git"
  },
  "homepage": "https://github.com/ozymandias724/aviphy",
  "bugs": {
    "url": "https://github.com/ozymandias724/aviphy/issues"
  },
  "keywords": [
    "avif",
    "gif",
    "webp",
    "animation",
    "encoder",
    "image",
    "conversion",
    "media",
    "compression"
  ]
}
