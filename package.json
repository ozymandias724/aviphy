{
  "name": "animated-image-to-avif",
  "version": "0.1.0",
  "description": "Animated image to AVIF conversion pipeline built with Bun and Sharp.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target bun && tsc -p tsconfig.build.json",
    "test": "bun test"
  },
  "keywords": [
    "avif",
    "gif",
    "webp",
    "animation",
    "encoder",
    "sharp",
    "bun"
  ],
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
